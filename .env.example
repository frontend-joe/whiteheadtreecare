# Resend (https://resend.com) — used by the "Get a Quote" form.
# Without RESEND_API_KEY the form still works in dev: submissions are logged
# to the server console instead of being emailed.

RESEND_API_KEY=
# Where quote requests are delivered (defaults to dave@whiteheadtreecare.com)
QUOTE_TO_EMAIL=dave@whiteheadtreecare.com
# Verified sender address in your Resend account (defaults to onboarding@resend.dev for testing)
QUOTE_FROM_EMAIL=onboarding@resend.dev
